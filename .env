# ============================================================
# FILE KONFIGURASI - .env
# Salin file ini menjadi ".env" dan isi sesuai konfigurasi kamu
# JANGAN pernah upload file .env ke GitHub!
# ============================================================

# Koneksi Database PostgreSQL
# Format: host=<host> user=<user> password=<pass> dbname=<nama_db> port=<port>
DATABASE_URL=host=localhost user=postgres password=102938 dbname=belajar-api port=5432 sslmode=disable

# Secret key untuk JWT (ganti dengan string acak yang panjang & unik!)
# Bisa generate di: https://generate-random.org/api-key-generator
JWT_SECRET=ganti-dengan-secret-key-yang-sangat-panjang-dan-acak-123!@#

# Port server (default: 8080)
PORT=8080
